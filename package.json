{
  "name": "@electerious/eslint-config",
  "version": "6.0.0-rc.1",
  "description": "ESLint configuration for my personal projects",
  "keywords": [
    "eslint",
    "eslintconfig"
  ],
  "homepage": "https://github.com/electerious/eslint-config",
  "repository": {
    "type": "git",
    "url": "https://github.com/electerious/eslint-config.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./react": "./src/react.js"
  },
  "main": "src/index.js",
  "files": [
    "src"
  ],
  "scripts": {
    "eslint": "eslint \"**/*.js\"",
    "format": "npm run eslint -- --fix && npm run prettier -- --write",
    "lint": "npm run eslint && npm run prettier -- --check",
    "prettier": "prettier --ignore-path .gitignore \"**/*.{js,json,md,yml}\"",
    "test": "npm run lint && node --test"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-node-test": "^0.3.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.11",
    "eslint-plugin-unicorn": "^70.0.0",
    "globals": "^17.7.0"
  },
  "devDependencies": {
    "@electerious/prettier-config": "^4.0.2",
    "prettier": "^3.9.4"
  },
  "peerDependencies": {
    "eslint": "^10.6.0"
  },
  "engines": {
    "node": ">=22"
  },
  "authors": [
    "Tobias Reich <tobias@electerious.com>"
  ]
}
